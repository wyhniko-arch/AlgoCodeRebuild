{
  "level_name": "初识搬运",
  "story": "你面前有一组数据存放在队列A中。你需要通过一系列操作将它们搬运到栈B中，并且最终栈B从顶到底为4,2,1,3。合理使用pop、push等指令完成任务。",
  "input_desc": "Queue(A) = (1,2,3,4)",
  "output_desc": "Stack(B) top = (4,2,1,3)",
  "struct_used": ["Queue", "Stack"],
  "commands_allowed": [
    {"struct_id": "Queue", "command_id": "pop", "max_uses": 5},
    {"struct_id": "Queue", "command_id": "add", "max_uses": 1},
    {"struct_id": "Stack", "command_id": "pop", "max_uses": 0},
    {"struct_id": "Stack", "command_id": "push", "max_uses": 0}
  ],
  "init_commands": [
    "Queue[(A),[(1,2,3,4)]]",
    "Stack[(B)]"
  ],
  "judge_commands": [
    "Stack[(B)].copy[(X)]",
    "Stack[(Y),[(1,3,4,2)]]",
    "Stack.equal[(X),(Y)]",
    "Stack[(X)].delete",
    "Stack[(Y)].delete"
  ],
  "buffer": {
    "command_in": "Stack[(B)].push",
    "command_out": "Stack[(B)].pop"
  },
  "steps_limit": 6
}
